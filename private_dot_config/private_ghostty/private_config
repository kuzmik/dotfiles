# ~/.config/ghostty/config

# Config generated by Ghostty Config
# https://ghostty.zerebos.com/

bell-audio-volume = 0
bell-features = no-attention,title,border
clipboard-read = allow
desktop-notifications = false
mouse-hide-while-typing = true
quick-terminal-animation-duration = 0.1
scrollback-limit = 10000000000
shell-integration-features = cursor,sudo,title,ssh-env
window-new-tab-position = end
window-subtitle = working-directory
working-directory = inherit

# MacOS specific settings
macos-option-as-alt = true
macos-titlebar-style = native
macos-window-shadow = false

# Typography
font-family = MonoLisa
font-feature = -calt,-liga,-dlig
font-size = 17
font-thicken = true

# Keybindings
keybind = ctrl+minus=text:\x1f
keybind = ctrl+plus=text:\x1f
keybind = ctrl+slash=text:\x1f
keybind = ctrl+bracket_left=text:\x1b
keybind = ctrl+bracket_right=text:\x1d
keybind = ctrl+backslash=text:\x1c
keybind = ctrl+enter=text:\x0d
keybind = ctrl+apostrophe=text:\x27
keybind = ctrl+semicolon=text:\x3b
keybind = ctrl+comma=text:\x2c
keybind = ctrl+period=text:\x2e
keybind = ctrl+grave_accent=text:\x60
# Make Option+arrows, Shift+arrows, and Ctrl+Shift+arrows inert (send nothing)
# instead of leaking escape sequences into the shell. `ignore` swallows the key;
# `unbind` would fall through and encode it (which caused the garbage on the line).
keybind = alt+arrow_up=ignore
keybind = alt+arrow_down=ignore
keybind = ctrl+shift+arrow_up=ignore
keybind = ctrl+shift+arrow_down=ignore
keybind = ctrl+shift+arrow_left=ignore
keybind = ctrl+shift+arrow_right=ignore
keybind = shift+arrow_left=ignore
keybind = shift+arrow_up=ignore
keybind = shift+page_up=unbind
keybind = shift+end=unbind
keybind = shift+arrow_right=ignore
keybind = shift+page_down=unbind
keybind = shift+arrow_down=ignore
keybind = shift+home=unbind

# Silence every remaining modifier+arrow combo so none can leak escape sequences
# into the shell. Kept useful: alt+left/right (word jump), super+arrows (line/
# prompt nav), super+alt/ctrl+arrows (split nav + resize), super+shift+up/down.
keybind = ctrl+arrow_up=ignore
keybind = ctrl+arrow_down=ignore
keybind = ctrl+arrow_left=ignore
keybind = ctrl+arrow_right=ignore
keybind = ctrl+alt+arrow_up=ignore
keybind = ctrl+alt+arrow_down=ignore
keybind = ctrl+alt+arrow_left=ignore
keybind = ctrl+alt+arrow_right=ignore
keybind = shift+alt+arrow_up=ignore
keybind = shift+alt+arrow_down=ignore
keybind = shift+alt+arrow_left=ignore
keybind = shift+alt+arrow_right=ignore
keybind = ctrl+alt+shift+arrow_up=ignore
keybind = ctrl+alt+shift+arrow_down=ignore
keybind = ctrl+alt+shift+arrow_left=ignore
keybind = ctrl+alt+shift+arrow_right=ignore
keybind = shift+super+arrow_left=ignore
keybind = shift+super+arrow_right=ignore
keybind = ctrl+shift+bracket_left=unbind
keybind = ctrl+shift+bracket_right=unbind
keybind = ctrl+shift+bracket_left=unbind
keybind = ctrl+shift+bracket_right=unbind
keybind = shift+super+d=new_split:right
keybind = super+shift+r=reload_config
keybind = super+d=new_split:down

# Visuals
background = #000000
background-blur = true
background-opacity = 0.85
cursor-color = #53ae71
cursor-style-blink = true
cursor-text = #000000
faint-opacity = 0.3
foreground = #b3b3b3
palette = 0=#000000
palette = 1=#cc5555
palette = 2=#55cc55
palette = 3=#cdcd55
palette = 4=#5555cc
palette = 5=#cc55cc
palette = 6=#7acaca
palette = 7=#cccccc
palette = 8=#555555
palette = 9=#ff5555
palette = 10=#55ff55
palette = 11=#ffff55
palette = 12=#5555ff
palette = 13=#ff55ff
palette = 14=#55ffff
palette = 15=#ffffff
scrollbar = never
selection-background = #4d52f8
selection-foreground = #000000
split-divider-color = #9E9A9A
theme = Wez
unfocused-split-opacity = 0.5
window-padding-balance = true
window-padding-x = 5
window-padding-y = 5
window-theme = dark
