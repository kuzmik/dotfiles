# From http://ghostty.zerebos.com/

background = #000000
background-blur = macos-glass-regular
background-opacity = 0.89
background-opacity = 0.9
bell-audio-volume = 0
bell-features = no-attention,no-title
clipboard-read = allow
clipboard-write = allow
copy-on-select = false
cursor-color = #53ae71
cursor-style-blink = true
cursor-text = #000000
desktop-notifications = false
faint-opacity = 0.3
font-family = MonoLisa
font-size = 17
font-thicken = true
foreground = #b3b3b3
keybind = super+shift+`=toggle_quick_terminal
keybind = super+shift+r=reload_config
macos-option-as-alt = true
macos-titlebar-style = native
macos-window-shadow = false
mouse-hide-while-typing = true
palette = 0=#000000
palette = 10=#55ff55
palette = 11=#ffff55
palette = 12=#5555ff
palette = 13=#ff55ff
palette = 14=#55ffff
palette = 15=#ffffff
palette = 1=#cc5555
palette = 2=#55cc55
palette = 3=#cdcd55
palette = 4=#5555cc
palette = 5=#cc55cc
palette = 6=#7acaca
palette = 7=#cccccc
palette = 8=#555555
palette = 9=#ff5555
quick-terminal-animation-duration = 0.1
scrollback-limit = 10000000000
scrollbar = never
selection-background = #4d52f8
selection-foreground = #000000
shell-integration-features = cursor,sudo,title
split-divider-color = #777777
theme = Wez
unfocused-split-opacity = 0.7
unfocused-split-opacity = 0.8
window-new-tab-position = end
window-padding-balance = true
window-padding-x = 5
window-padding-y = 5
window-show-tab-bar = always
window-subtitle = working-directory
window-theme = auto
working-directory = inherit
