# ~/.config/starship.toml

{{- if eq .chezmoi.hostname "nick-kuzmik-ML-L2KCW7KQTD" }}
format = "$gcloud $kubernetes$python\n$time <$username@$hostname:$directory$git_branch$git_status $cmd_duration $status > "
{{ else }}
format = "$kubernetes$python\n$time <$username@$hostname:$directory$git_branch$git_status $cmd_duration $status > "
{{- end }}

# Disable the blank line at the start of the prompt
add_newline = false

[cmd_duration]
disabled = false
min_time =   20
format = '$duration'

[time]
disabled = false
time_format = "%H:%M:%S"
format = "[$time](none)"

[username]
disabled = false
show_always = true
format = "[$user](cyan)"

[hostname]
disabled = false
ssh_only = false
format = "[$hostname](cyan)"
aliases = {
  "nick-kuzmik-ML-L2KCW7KQTD" = "adro",
}

[directory]
disabled = false
truncate_to_repo = true
use_logical_path = true
format = "[$path](bold blue)"

[status]
disabled = false
symbol = "[\\$](red)"
success_symbol = "[\\$](green)"
format = "[$symbol](none)"
map_symbol = false

[git_branch]
disabled = false
symbol = "?"
truncation_symbol = ""
ignore_branches = []
format = "[\\($branch\\)](green)"

[git_status]
disabled = false
style = "yellow"
up_to_date = "!"
format = "[\\($all_status\\)]($style)"

[gcloud]
format = '[$account](dimmed cyan):[$project](yellow),'
disabled = false

[kubernetes]
format = '[kctx](dimmed cyan):[$context]($style)$symbol, [kns](dimmed cyan):[$namespace](yellow)'
disabled = false
style = "yellow"
symbol = ""

[python]
disabled = false
pyenv_version_name = true
pyenv_prefix = 'pyenv'
style = "dimmed green"
symbol = ""
format = ', [${pyenv_prefix}](dimmed cyan):[(${version})($virtualenv)](yellow)'

# assumes all stacks are prod, even though we have some test stacks; to deal with later
[[kubernetes.contexts]]
context_pattern = "(?<cluster>stack-\\d{4})-(?P<region>.+)-\\d{2}.+"
context_alias = "$region/prod-$cluster"
style = "bold red"

# filter out the data-products-staging cluster from the prod grouping
[[kubernetes.contexts]]
context_pattern = ".+-(prod|production)-.+"
style = "bold red"

[[kubernetes.contexts]]
context_pattern = ".+fedramp-demo.+"
context_alias = "fedramp-prod"
style = "bold red"

[[kubernetes.contexts]]
context_pattern = ".+fedramp-test.+"
context_alias = "fedramp-staging"

