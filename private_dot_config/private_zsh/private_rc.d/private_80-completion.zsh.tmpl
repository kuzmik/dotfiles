# ~/.config/zsh/rc.d/80-completion.zsh
#
# Completion system. Runs last so compinit sees everything on fpath, and the
# deferred fzf-tab plugin (loaded via sheldon in 60-plugins) lands after it.

# +---------+
# | General |
# +---------+

{{ if eq .osid "darwin" }}
# Load more completions
fpath=(
  /opt/homebrew/completions/zsh
  /opt/homebrew/share/zsh/site-functions
  $fpath
)
{{ end }}

# Should be called before compinit
zmodload zsh/complist

# Use hjlk in menu selection (during completion)
# Doesn't work well with interactive mode
bindkey -M menuselect 'h' vi-backward-char
bindkey -M menuselect 'k' vi-up-line-or-history
bindkey -M menuselect 'j' vi-down-line-or-history
bindkey -M menuselect 'l' vi-forward-char

bindkey -M menuselect '^xg' clear-screen
bindkey -M menuselect '^xi' vi-insert                      # Insert
bindkey -M menuselect '^xh' accept-and-hold                # Hold
bindkey -M menuselect '^xn' accept-and-infer-next-history  # Next
bindkey -M menuselect '^xu' undo                           # Undo

autoload -Uz compinit
if [ "$(date +'%j')" != "$(stat -f '%Sm' -t '%j' {{ .chezmoi.homeDir }}/.config/zsh/.zcompdump 2>/dev/null)" ]; then
    compinit
else
    compinit -C
fi

_comp_options+=(globdots)   # With hidden files

compdef vman="man"

# +---------+
# | Options |
# +---------+

# setopt GLOB_COMPLETE      # Show autocompletion menu with globs
setopt MENU_COMPLETE        # Automatically highlight first element of completion menu
setopt AUTO_LIST            # Automatically list choices on ambiguous completion.
setopt COMPLETE_IN_WORD     # Complete from both ends of a word.

# +---------+
# | zstyles |
# +---------+

# zstyle pattern
# :completion:<function>:<completer>:<command>:<argument>:<tag>

# Define completers
zstyle ':completion:*' completer _extensions _complete _approximate

# Use cache for commands using cache
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path "$ZDOTDIR/zcompcache"

# Complete the alias when _expand_alias is used as a function
zstyle ':completion:*' complete true

zle -C alias-expension complete-word _generic
bindkey '^Xa' alias-expension
zstyle ':completion:alias-expension:*' completer _expand_alias

# Allow you to select in a menu
zstyle ':completion:*' menu select

# Autocomplete options for cd instead of directory stack
zstyle ':completion:*' complete-options true
zstyle ':completion:*' file-sort modification

zstyle ':completion:*:*:*:*:corrections' format '%F{yellow}!- %d (errors: %e) -!%f'
zstyle ':completion:*:*:*:*:descriptions' format '%F{blue}-- %D %d --%f'
zstyle ':completion:*:*:*:*:messages' format ' %F{purple} -- %d --%f'
zstyle ':completion:*:*:*:*:warnings' format ' %F{red}-- no matches found --%f'
# zstyle ':completion:*:default' list-prompt '%S%M matches%s'

# Colors for files and directory
zstyle ':completion:*:*:*:*:default' list-colors ${(s.:.)LS_COLORS}

# Only display some tags for the command cd
zstyle ':completion:*:*:cd:*' tag-order local-directories directory-stack path-directories
zstyle ':completion:*:complete:git:argument-1:' tag-order !aliases

# Required for completion to be in good groups (named after the tags)
zstyle ':completion:*' group-name ''
zstyle ':completion:*:*:-command-:*:*' group-order aliases builtins functions commands

# Hide autoloaded completion helpers (_elinks, _elfdump, _gcloud-secrets-*, etc.)
# from the "functions" tag so they don't pollute command completion.
zstyle ':completion:*:functions' ignored-patterns '_*'

# See ZSHCOMPWID "completion matching control"
zstyle ':completion:*' matcher-list '' 'm:{a-zA-Z}={A-Za-z}' 'r:|[._-]=* r:|=*' 'l:|=* r:|=*'
zstyle ':completion:*' keep-prefix true

zstyle -e ':completion:*:(ssh|scp|sftp|rsh|rsync):hosts' hosts 'reply=(${=${${(f)"$(cat {/etc/ssh_,{{ .chezmoi.homeDir }}/.ssh/known_}hosts(|2)(N) /dev/null)"}%%[# ]*}//,/ })'

# gcloud completion via mise (PATH setup lives in 00-path).
# completion.zsh.inc calls compdef, so it must run after compinit above.
if [ -d "$XDG_DATA_HOME/mise/installs/gcloud" ]; then
  . "$XDG_DATA_HOME/mise/installs/gcloud/latest/completion.zsh.inc"
fi

# ps/kill completion
zstyle ':completion:*:*:*:*:processes' command "ps -u $USER -o pid,user,comm -w -w"
zstyle ':fzf-tab:complete:(kill|ps):argument-rest' fzf-preview '[[ $group == "[process ID]" ]] && ps --pid=$word -o cmd --no-headers -w -w'
zstyle ':fzf-tab:complete:(kill|ps):argument-rest' fzf-flags --preview-window=down:3:wrap

# Homebrew
zstyle ':fzf-tab:complete:brew-(install|uninstall|search|info):*-argument-rest' fzf-preview 'brew info $word'

# env vars
zstyle ':fzf-tab:complete:(-command-|-parameter-|-brace-parameter-|export|unset|expand):*' fzf-preview 'echo ${(P)word}'

# files & directories: preview file contents (bat) or dir tree while tab-completing.
# Least-specific pattern, so the targeted previews above still win where they match.
zstyle ':fzf-tab:complete:*:*' fzf-preview \
  '[[ -d $realpath ]] && tree -C $realpath | head -100 || bat --color=always --style=numbers -- $realpath 2>/dev/null || echo $realpath'

if (( $+commands[fzf] )); then
  # Ctrl-R is owned by atuin (see 60-plugins), so no FZF_CTRL_R_OPTS here.
  export FZF_DEFAULT_OPTS="
    --height 60% --layout=reverse --border --cycle --info=inline
    --bind 'ctrl-k:kill-line'
    --bind 'ctrl-/:toggle-preview'
    --bind 'ctrl-u:preview-half-page-up,ctrl-d:preview-half-page-down'"

  if (( $+commands[rg] )); then
    # Respect .gitignore (no --no-ignore-vcs) so the picker isn't flooded with
    # node_modules/build junk. --glob=!.git + --hidden come from the rg config.
    export FZF_DEFAULT_COMMAND="rg --files --hidden --follow"
  fi

  # Ctrl-T: insert file paths at the cursor (preview via bat)
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
  export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers -- {}'"

  # Alt-C: fuzzy-cd into a subdirectory (preview its tree)
  if (( $+commands[fd] )); then
    export FZF_ALT_C_COMMAND="fd --type d --hidden --follow --exclude .git"
  fi
  export FZF_ALT_C_OPTS="--preview 'tree -C {} | head -100'"
fi

{{- if .workMode }}
# Completion function to list gcp projects for the gsl function
_gcloud-secrets-list() {
  local projects
  projects=($(gcloud projects list --filter="NOT (projectId:gam-* OR projectId:sys-*)" --format="value(projectId)" 2>/dev/null))

  _describe 'projects' projects
}
compdef _gcloud-secrets-list gsl

# Completion function for gcloud-secrets-access
_gcloud-secrets-access() {
  local context state line

  _arguments \
    '1:project:->projects' \
    '2:secret:->secrets' \
    '*::arguments:->args'

  case $state in
    projects)
      local projects
      projects=($(gcloud projects list --format="value(projectId)" --filter="NOT (projectId:gam-* OR projectId:sys-*)" 2>/dev/null))
      _describe 'projects' projects
    ;;
    secrets)
      if [[ -n $line[1] ]]; then
        local secrets
        secrets=($(gcloud secrets list --project="$line[1]" --format="value(name)" 2>/dev/null))
        _describe 'secrets' secrets
      fi
    ;;
  esac
}
compdef _gcloud-secrets-access gsa

# setup completion for the context command, if it exists
if (( $+commands[context] )); then
  eval "$(context --completion-setup)"
fi
{{- end }}
